# Ghostty configuration
# Matches kitty.conf settings

# Font configuration
font-family = "Fira Code"
font-family-italic = "Monaspace Radon Var"
font-family-bold-italic = "Monaspace Radon Var"
font-size = 17
font-variation = wght=400
font-variation-bold = wght=700
# Fira Code features (regular/bold)
font-feature = +calt
font-feature = +liga
font-feature = +cv06
font-feature = +cv14
font-feature = +zero
font-feature = +ss02
font-feature = +ss07
# Monaspace Radon features (italic/bold-italic); font-feature is global but
# features unsupported by a font are silently ignored.
# +cv01 is intentionally omitted: it changes Fira Code's 'a' glyph as a side effect,
# since Ghostty cannot scope features per font family.
font-feature = +ss01
font-feature = +ss03
font-feature = +ss04
font-feature = +ss05
font-feature = +ss06
font-feature = +ss08

# Line height (cell height adjustment)
adjust-cell-height = 20%

# Window padding (top=8, bottom=0 to match kitty)
window-padding-x = 8
window-padding-y = 8,0
window-padding-balance = false

# Quit when last window closed
quit-after-last-window-closed = true

# Cursor configuration
cursor-style = block
cursor-style-blink = true

# Prevent shell from overriding cursor shape
shell-integration-features = no-cursor

# Word navigation with Option+Left/Right
# These send Alt+b/f for shell/tmux word navigation
keybind = alt+left=esc:b
keybind = alt+right=esc:f

# Clipboard bindings
keybind = super+v=paste_from_clipboard
keybind = super+c=copy_to_clipboard

# Color scheme - Tomorrow Night (from kitty themes/Tomorrow_Night.conf)
background = #1d1f21
foreground = #c5c8c6

# ANSI colors
palette = 0=#1d1f21
palette = 1=#cc6666
palette = 2=#b5bd68
palette = 3=#f0c674
palette = 4=#81a2be
palette = 5=#b294bb
palette = 6=#8abeb7
palette = 7=#c5c8c6
palette = 8=#969896
palette = 9=#cc6666
palette = 10=#b5bd68
palette = 11=#f0c674
palette = 12=#81a2be
palette = 13=#b294bb
palette = 14=#8abeb7
palette = 15=#ffffff

# Selection colors
selection-background = #c5c8c6
selection-foreground = #1d1f21

# Cursor colors
cursor-color = #c5c8c6
cursor-text = #1d1f21
