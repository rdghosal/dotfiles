{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "background":    "#1d1f21",
    "bgPanel":       "#282a2e",
    "bgElement":     "#373b41",
    "comment":       "#969896",
    "textMid":       "#b4b7b4",
    "text":          "#c5c8c6",
    "white":         "#e0e0e0",
    "red":           "#cc6666",
    "orange":        "#de935f",
    "yellow":        "#f0c674",
    "green":         "#b5bd68",
    "teal":          "#8abeb7",
    "blue":          "#81a2be",
    "purple":        "#b294bb"
  },
  "theme": {
    "primary": {
      "dark": "blue",
      "light": "blue"
    },
    "secondary": {
      "dark": "purple",
      "light": "purple"
    },
    "accent": {
      "dark": "teal",
      "light": "teal"
    },
    "error": {
      "dark": "red",
      "light": "red"
    },
    "warning": {
      "dark": "orange",
      "light": "orange"
    },
    "success": {
      "dark": "green",
      "light": "green"
    },
    "info": {
      "dark": "blue",
      "light": "blue"
    },
    "text": {
      "dark": "text",
      "light": "text"
    },
    "textMuted": {
      "dark": "comment",
      "light": "comment"
    },
    "background": {
      "dark": "background",
      "light": "background"
    },
    "backgroundPanel": {
      "dark": "bgPanel",
      "light": "bgPanel"
    },
    "backgroundElement": {
      "dark": "bgElement",
      "light": "bgElement"
    },
    "border": {
      "dark": "bgElement",
      "light": "bgElement"
    },
    "borderActive": {
      "dark": "comment",
      "light": "comment"
    },
    "borderSubtle": {
      "dark": "bgPanel",
      "light": "bgPanel"
    },
    "diffAdded": {
      "dark": "green",
      "light": "green"
    },
    "diffRemoved": {
      "dark": "red",
      "light": "red"
    },
    "diffContext": {
      "dark": "comment",
      "light": "comment"
    },
    "diffHunkHeader": {
      "dark": "blue",
      "light": "blue"
    },
    "diffHighlightAdded": {
      "dark": "green",
      "light": "green"
    },
    "diffHighlightRemoved": {
      "dark": "red",
      "light": "red"
    },
    "diffAddedBg": {
      "dark": "#2a3020",
      "light": "#2a3020"
    },
    "diffRemovedBg": {
      "dark": "#2d2020",
      "light": "#2d2020"
    },
    "diffContextBg": {
      "dark": "bgPanel",
      "light": "bgPanel"
    },
    "diffLineNumber": {
      "dark": "comment",
      "light": "comment"
    },
    "diffAddedLineNumberBg": {
      "dark": "#263020",
      "light": "#263020"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#2d1f1f",
      "light": "#2d1f1f"
    },
    "markdownText": {
      "dark": "text",
      "light": "text"
    },
    "markdownHeading": {
      "dark": "blue",
      "light": "blue"
    },
    "markdownLink": {
      "dark": "purple",
      "light": "purple"
    },
    "markdownLinkText": {
      "dark": "teal",
      "light": "teal"
    },
    "markdownCode": {
      "dark": "green",
      "light": "green"
    },
    "markdownBlockQuote": {
      "dark": "comment",
      "light": "comment"
    },
    "markdownEmph": {
      "dark": "orange",
      "light": "orange"
    },
    "markdownStrong": {
      "dark": "yellow",
      "light": "yellow"
    },
    "markdownHorizontalRule": {
      "dark": "bgElement",
      "light": "bgElement"
    },
    "markdownListItem": {
      "dark": "blue",
      "light": "blue"
    },
    "markdownListEnumeration": {
      "dark": "teal",
      "light": "teal"
    },
    "markdownImage": {
      "dark": "purple",
      "light": "purple"
    },
    "markdownImageText": {
      "dark": "teal",
      "light": "teal"
    },
    "markdownCodeBlock": {
      "dark": "text",
      "light": "text"
    },
    "syntaxComment": {
      "dark": "comment",
      "light": "comment"
    },
    "syntaxKeyword": {
      "dark": "purple",
      "light": "purple"
    },
    "syntaxFunction": {
      "dark": "blue",
      "light": "blue"
    },
    "syntaxVariable": {
      "dark": "red",
      "light": "red"
    },
    "syntaxString": {
      "dark": "green",
      "light": "green"
    },
    "syntaxNumber": {
      "dark": "orange",
      "light": "orange"
    },
    "syntaxType": {
      "dark": "yellow",
      "light": "yellow"
    },
    "syntaxOperator": {
      "dark": "teal",
      "light": "teal"
    },
    "syntaxPunctuation": {
      "dark": "text",
      "light": "text"
    }
  }
}
